# ============================================================
# Pi MI — Configuration
# Copy this file and fill in your values before running:
#   cp config.env.example config.env
#   nano config.env
#
# config.env is gitignored — never commit it.
# ============================================================

# ── Required ──────────────────────────────────────────────────────────────────
S3_BUCKET=""                             # S3 bucket name (must already exist)
S3_REGION="us-east-1"                    # AWS region where your bucket lives

# ntfy.sh push notification URL (optional) — get a free topic at https://ntfy.sh
# Leave blank to run silently. Example: https://ntfy.sh/my-pi-backups
NTFY_URL=""

# ── AWS credentials ───────────────────────────────────────────────────────────
# Leave blank to use the default profile (~/.aws/credentials) or an IAM role.
# Set to a named profile if you use multiple AWS accounts.
# WARNING: do not set this to "" — an empty string causes AWS CLI to fail with
# "profile not found". Leave it commented out or set a real profile name.
#AWS_PROFILE=""

# ── Retention ─────────────────────────────────────────────────────────────────
# Number of nightly images to keep. Older images are deleted automatically.
#
# Cost estimate (STANDARD_IA, ~10GB compressed per image):
#   7 images  ≈  70GB  ≈  ~$1/month   (1 week rolling window)
#  30 images  ≈ 300GB  ≈  ~$4/month   (1 month rolling window)
#  60 images  ≈ 600GB  ≈  ~$8/month   (2 month rolling window)
#
# Actual compressed size depends heavily on how full your disk is.
# A 128GB NVMe that is 20% full typically compresses to 8–15GB.
# Run with --dry-run after first backup to see your actual size.
MAX_IMAGES=60

# Per-host retention override (multi-Pi setups).
# Hyphens in hostname must be replaced with underscores.
# Example: host "my-pi-5" → MAX_IMAGES_my_pi_5=30
# Leave blank to use the global MAX_IMAGES above.
#MAX_IMAGES_my_pi_5=30
#MAX_IMAGES_pi_zero=7

# ── Client-side encryption (optional) ────────────────────────────────────────
# Encrypts each partition image with gpg AES-256 before uploading to S3.
# Protects backup data if AWS credentials are compromised — even full bucket
# access is useless without this passphrase. Passphrase lives in config.env
# only; never stored in S3.
#
# Requires: sudo apt install gpg
# Leave blank to rely on S3 server-side encryption only (SSE-S3 baseline).
# To restore, set this same passphrase in config.env on the restore machine,
# or the restore script will prompt interactively.
BACKUP_ENCRYPTION_PASSPHRASE=""

# ── Bandwidth throttle (optional) ────────────────────────────────────────────
# Limit S3 upload speed to avoid saturating your network during backup.
# Requires: sudo apt install pv
# Uses pv rate format: 2m = 2 MB/s, 500k = 500 KB/s, 1g = 1 GB/s.
# Leave blank for unlimited.
AWS_TRANSFER_RATE_LIMIT=""

# ── Storage class ─────────────────────────────────────────────────────────────
# STANDARD_IA  = 40% cheaper than STANDARD; min 30-day charge. Best for backups.
# STANDARD     = no minimum charge; use if you restore frequently.
# ONEZONE_IA   = cheapest; not replicated across AZs.
# GLACIER_IR   = very cheap; retrieval takes milliseconds but costs more per GB out.
S3_STORAGE_CLASS="STANDARD_IA"

# ── Pre/post backup hooks (optional) ─────────────────────────────────────────
# Shell commands to run immediately before and after the partition imaging phase.
# Use these if you run services outside of Docker that need to be stopped for a
# consistent snapshot — e.g. native MySQL, MariaDB, nginx, Apache, php-fpm.
#
# PRE_BACKUP_CMD  runs after preflight, before imaging. If it exits non-zero,
#                 the backup is aborted immediately (no partial image taken).
# POST_BACKUP_CMD runs after imaging completes. The on_exit trap also calls it
#                 if the script crashes mid-imaging, so services always restart.
#
# STOP_DOCKER=true and PRE/POST hooks can coexist — Docker is stopped first,
# then PRE_BACKUP_CMD runs, then imaging, then POST_BACKUP_CMD, then Docker restarts.
#
# Native WordPress example (nginx + php-fpm + MariaDB as systemd services):
#   PRE_BACKUP_CMD="systemctl stop nginx php8.2-fpm mariadb"
#   POST_BACKUP_CMD="systemctl start mariadb php8.2-fpm nginx"
#
# Leave blank if you only use Docker (STOP_DOCKER=true handles that case).
PRE_BACKUP_CMD=""
POST_BACKUP_CMD=""

# ── MariaDB/MySQL consistent snapshot (zero-downtime DB lock) ─────────────────
# Issues FLUSH TABLES WITH READ LOCK before imaging and UNLOCK TABLES after.
# All containers/services stay running — reads and cached pages are served
# throughout. Only DB writes are blocked during the imaging window (~5-15 min).
# This replaces STOP_DOCKER for setups that run MariaDB or MySQL.
#
# DB_CONTAINER controls how the DB is found:
#   "auto"        = detect automatically (scans running containers for mariadb/mysql image)
#   "pi_mariadb"  = explicit container name
#   ""            = no Docker; use native mariadb/mysql command on localhost
#
# DB_ROOT_PASSWORD: leave blank to auto-read MYSQL_ROOT_PASSWORD / MARIADB_ROOT_PASSWORD
# from the container's environment (works for standard Docker Compose setups).
# Set explicitly for native installs or if auto-read fails.
#
# If DB_CONTAINER="auto" and no MariaDB/MySQL container is found, falls back to
# STOP_DOCKER. If both DB_CONTAINER and DB_ROOT_PASSWORD are blank, STOP_DOCKER is used.
DB_CONTAINER="auto"
DB_ROOT_PASSWORD=""

# ── Site availability probe ───────────────────────────────────────────────────
# Pings your site every PROBE_INTERVAL seconds while partclone runs, to verify
# the site stays up during the DB lock. Results logged and included in ntfy.
#
# PROBE_URL: URL to probe. Leave blank to auto-detect from CF_SITE_HOSTNAME.
# PROBE_INTERVAL: seconds between probes (default: 60).
#
# Each probe is cache-busted (?pi2s3t=<timestamp>) with Cache-Control: no-cache.
PROBE_URL=""
PROBE_INTERVAL=60

# ── Backup behaviour ──────────────────────────────────────────────────────────
# Stop Docker containers briefly before imaging for a consistent snapshot.
# Only used if DB_CONTAINER / DB_ROOT_PASSWORD are not configured above.
STOP_DOCKER=true
DOCKER_STOP_TIMEOUT=30

# Cron schedule for nightly backup (default: 2:00am every day).
# Uses standard cron syntax. Check: https://crontab.guru
CRON_SCHEDULE="0 2 * * *"

# Extra device to image alongside the boot device.
# Only needed if your Docker data (or other critical data) lives on a SEPARATE
# physical device from where your OS boots. pi-image-backup.sh will warn you
# during preflight if it detects this situation.
#
# Example: SD card boots OS, but Docker data root is on an external USB NVMe:
#   BACKUP_EXTRA_DEVICE="/dev/sda"
#
# Leave blank if everything is on one device (most NVMe setups).
BACKUP_EXTRA_DEVICE=""

# ── Notifications ─────────────────────────────────────────────────────────────
# "all"     = notify on both success and failure (recommended while getting started)
# "failure" = only notify on failure — change this once you trust the backup is reliable
NTFY_LEVEL="all"

# ── Post-backup container safety check ───────────────────────────────────────
# Runs a separate cron job ~30 min after the backup to verify Docker containers
# came back up. Guards against the backup script crashing mid-imaging and leaving
# containers stopped (on top of the on_exit trap in the backup script itself).
#
# Cron schedule should be BACKUP_START + enough time for imaging to finish.
# Default: 30 min after the default 2:00 AM backup → 2:30 AM.
# Adjust if your backup typically takes longer than 30 minutes.
POST_BACKUP_CHECK_ENABLED=true
POST_BACKUP_CHECK_SCHEDULE="30 2 * * *"

# ── Cloudflare tunnel watchdog (optional) ─────────────────────────────────────
# Self-healing monitor for Pis that serve traffic via a Cloudflare tunnel.
# Runs every 5 min as root, auto-recovers through 3 escalating phases.
# Only needed if you run cloudflared on your Pi.
#
# Set CF_WATCHDOG_ENABLED=true then run: bash install.sh --watchdog
# Full configuration: see extras/config.env.example

CF_WATCHDOG_ENABLED=false
CF_SITE_HOSTNAME=""            # public hostname — used in notifications and probe URL

# ── test-recovery.sh — expected containers ───────────────────────────────────
# Space-separated list of container names that must be running after a restore.
# Used by: bash test-recovery.sh --post-boot
# Leave blank to skip the per-container check.
# Example: EXPECTED_CONTAINERS="mariadb wordpress nginx"
EXPECTED_CONTAINERS=""

# ── Post-backup auto-verify ──────────────────────────────────────────────────
# After every backup, re-checks S3 to confirm all uploaded files are non-zero.
# Result is included in the ntfy success notification.
# Set to false to skip (not recommended — this is your last line of defence
# against a silent upload failure).
BACKUP_AUTO_VERIFY=true

# ── Pre-backup health checks ──────────────────────────────────────────────────
# Runs before stopping Docker. Checks container health, free disk space, and
# recent I/O errors. Warns in log and ntfy on issues found.
#
# PREFLIGHT_ABORT_ON_WARN=true will abort the backup on any warning (default: false,
# proceed with warnings so a degraded-but-running stack still gets backed up).
PREFLIGHT_ENABLED=true
PREFLIGHT_MIN_FREE_MB=500
PREFLIGHT_ABORT_ON_WARN=false

# ── Missed backup alert ────────────────────────────────────────────────────────
# Runs a daily cron job that checks S3 for a recent backup and ntfys if none
# has been seen within STALE_BACKUP_HOURS. Catches silent cron failures.
#
# Set STALE_CHECK_ENABLED=true then re-run install.sh.
# Schedule should be well after your backup window (default: 6am, 4h after 2am backup).
STALE_CHECK_ENABLED=true
STALE_CHECK_SCHEDULE="0 6 * * *"
STALE_BACKUP_HOURS=25

# ── Daily heartbeat ping (optional) ──────────────────────────────────────────
# Sends a daily "I'm alive" push notification via ntfy with uptime, RAM,
# disk usage, and Docker container count. If this notification stops arriving,
# the Pi is down or unreachable.
#
# Set NTFY_HEARTBEAT_ENABLED=true then run: bash install.sh
# (or run: bash install.sh if this was set before the initial install)
NTFY_HEARTBEAT_ENABLED=false

# Cron schedule for heartbeat ping (default: 8:00am every day).
NTFY_HEARTBEAT_SCHEDULE="0 8 * * *"

# ── Hot standby: zero-downtime backup + daily sync ────────────────────────────
#
# Two complementary features that work together:
#
# 1) Zero-downtime backup (PRIMARY Pi)
#    Before the backup starts, STANDBY_FAILOVER_CMD moves traffic to the standby.
#    After the backup is verified in S3, STANDBY_FAILBACK_CMD restores traffic to
#    primary and writes a sync marker to S3.
#
# 2) Daily standby sync (STANDBY Pi)
#    hot-standby-sync.sh runs on the standby as a cron job. When it detects a new
#    sync marker, it reboots to SD, restores NVMe from S3, runs the post-restore
#    script (tunnel/hostname swap), then reboots back to NVMe — ready for failover.
#    Standby is offline ~30 min during the restore cycle.
#
# Full setup: bash extras/install-standby-sync.sh  (run on standby Pi)
# Failover scripts: extras/failover/  (cf-dns-swap.sh, route53-swap.sh, or your own)
# Post-restore template: extras/post-restore-standby-example.sh
#
# ── Primary Pi settings (set in PRIMARY's config.env) ────────────────────────
# Set true to enable failover-before-backup on the primary Pi.
HOT_STANDBY_ENABLED=false

# Command to run before backup starts (swap traffic TO standby).
# Provider scripts in extras/failover/ — or provide any shell command.
#
# Cloudflare example:
#   STANDBY_FAILOVER_CMD="bash ~/pi2s3/extras/failover/cf-dns-swap.sh --to-standby"
#
# Route 53 example:
#   STANDBY_FAILOVER_CMD="bash ~/pi2s3/extras/failover/route53-swap.sh --to-standby"
#
# Custom webhook example:
#   STANDBY_FAILOVER_CMD="curl -s -X POST https://lb.example.com/failover -d '{\"target\":\"standby\"}'"
STANDBY_FAILOVER_CMD=""

# Command to run after backup is verified in S3 (swap traffic BACK to primary).
# Cloudflare example:
#   STANDBY_FAILBACK_CMD="bash ~/pi2s3/extras/failover/cf-dns-swap.sh --to-primary"
STANDBY_FAILBACK_CMD=""

# Domain to read DNS TTL from after failover. Used to gauge propagation time
# when no STANDBY_VERIFY_URL is set. Leave blank if using a reverse proxy
# (instant swap) or if polling STANDBY_VERIFY_URL directly.
STANDBY_VERIFY_DOMAIN=""

# URL polled after failover. Backup proceeds only once this URL returns HTTP
# 2xx/3xx — confirming standby is actually serving requests. Strongly recommended.
# Example: https://yourdomain.com
STANDBY_VERIFY_URL=""

# URL polled after failback to confirm primary is up before writing the sync
# marker. Leave blank to skip (sync marker is written immediately on failback).
STANDBY_PRIMARY_VERIFY_URL=""

# Max seconds to wait for failover/failback confirmation (default: 300 = 5 min).
STANDBY_FAILOVER_TIMEOUT_SECS=300

# S3 key for the sync-ready marker written after each successful backup.
# Must match STANDBY_SYNC_MARKER_KEY on the standby Pi's config.env.
STANDBY_SYNC_MARKER_KEY="standby-sync-ready/latest.json"

# ── Cloudflare DNS swap settings (extras/failover/cf-dns-swap.sh) ────────────
# CF_ZONE_ID=""                   # Cloudflare zone ID (zone dashboard Overview)
# CF_API_TOKEN=""                 # CF API token — needs Zone:DNS:Edit permission
# CF_FAILOVER_DOMAINS=""          # Comma-separated CNAMEs: "yourdomain.com,www.yourdomain.com"
# PROD_TUNNEL_UUID=""             # Production CF Tunnel UUID
# STANDBY_TUNNEL_UUID=""          # Standby CF Tunnel UUID

# ── Route 53 DNS swap settings (extras/failover/route53-swap.sh) ─────────────
# R53_HOSTED_ZONE_ID=""           # e.g. Z1D633PJN98FT9
# R53_FAILOVER_DOMAINS=""         # Comma-separated: "yourdomain.com,www.yourdomain.com"
# R53_RECORD_TYPE="CNAME"         # A, AAAA, or CNAME
# R53_TTL=60                      # Low TTL recommended for fast propagation
# PROD_RECORD_VALUE=""            # Record value when pointing at primary
# STANDBY_RECORD_VALUE=""         # Record value when pointing at standby

# ── Standby Pi settings (set in STANDBY's config.env) ────────────────────────
# Set true on the STANDBY Pi to enable daily sync detection.
HOT_STANDBY_SYNC_ENABLED=false

# Block device to restore each sync cycle (the standby NVMe).
STANDBY_SYNC_DEVICE="/dev/nvme0n1"

# SD card boot partition used to write the restore trigger.
# Usually mmcblk0p1 on Raspberry Pi hardware.
STANDBY_SYNC_SD_BOOT="/dev/mmcblk0p1"

# SD card root partition — pi2s3 tools are installed here by install-standby-sync.sh.
STANDBY_SYNC_SD_ROOT="/dev/mmcblk0p2"

# Cron schedule for the sync check (default: every 30 min).
STANDBY_SYNC_CRON="*/30 * * * *"

# Post-restore script to run after each sync. Swap CF tunnel UUID, update hostname,
# etc. Copy extras/post-restore-standby-example.sh and fill it in.
# IMPORTANT: This script runs from the SD card environment and receives the
# restored NVMe mount point as $RESTORE_ROOT. Keep it idempotent — it runs
# after every sync cycle.
STANDBY_POST_RESTORE_SCRIPT=""

# URL checked before each sync to confirm primary is serving. If primary is
# unreachable (and this standby is serving traffic), the sync is skipped to
# avoid taking the standby offline. Strongly recommended.
# Example: https://yourdomain.com
STANDBY_SYNC_PRIMARY_URL=""

# S3 key for sync marker — must match STANDBY_SYNC_MARKER_KEY on primary.
# STANDBY_SYNC_MARKER_KEY="standby-sync-ready/latest.json"
