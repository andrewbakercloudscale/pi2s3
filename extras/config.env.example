# ============================================================
# pi2s3 extras — configuration
# Copy the sections you need into your ~/pi2s3/config.env
# ============================================================

# ── Cloudflare tunnel watchdog ────────────────────────────────────────────────
# Your site's public hostname — used in push notifications and HTTP probe.
# Example: "mysite.com" or "pi.example.com"
CF_SITE_HOSTNAME=""

# Local HTTP port to probe for liveness (default: 80).
CF_HTTP_PORT=80

# URL path to probe (default: /)
CF_HTTP_PROBE_PATH="/"

# Cloudflare tunnel metrics endpoint.
# Enable in cloudflared config with: metrics: localhost:20241
CF_METRICS_URL="http://127.0.0.1:20241/metrics"

# Path to your docker-compose.yml directory (used in Phase 2 full stack restart).
# Leave blank to auto-detect, or set explicitly if auto-detect misses it.
CF_COMPOSE_DIR=""

# Recovery escalation thresholds
CF_PHASE1_MAX=4              # attempts before Phase 2 (full compose restart)
CF_PHASE2_MAX=8              # attempts before Phase 3 (Pi reboot)
CF_REBOOT_MIN_INTERVAL=21600 # seconds between watchdog-triggered reboots (6 hours)


# ── PHP-FPM saturation monitor (WordPress) ────────────────────────────────────
# Detects worker pool exhaustion and orphaned DB locks. Alerts via ntfy.
# Set FPM_AUTO_RESTART=true to restart the WordPress container automatically.

FPM_SATURATION_THRESHOLD=3       # consecutive saturated checks before alerting (default: 3)
FPM_PROBE_URL=http://localhost:80/
FPM_PROBE_TIMEOUT=5
FPM_WP_CONTAINER=wordpress       # name of your WordPress Docker container
FPM_DB_CONTAINER=mariadb         # name of your MariaDB Docker container
FPM_ALERT_COOLDOWN=1800          # seconds between repeat alerts (default: 30 min)
FPM_AUTO_RESTART=false           # true = docker restart FPM_WP_CONTAINER automatically
FPM_RESTART_COOLDOWN=1200        # seconds between auto-restarts (default: 20 min)

# DB root password for orphaned-lock detection.
# Leave blank to auto-read from the container environment.
FPM_DB_ROOT_PASSWORD=""

# Site hostname in ntfy alert titles (defaults to CF_SITE_HOSTNAME or $(hostname)).
FPM_SITE_HOSTNAME=""

# Optional — report events to CloudScale Devtools plugin (Debug AI → PHP-FPM Monitor):
# FPM_CALLBACK_URL=https://yoursite.com/wp-admin/admin-ajax.php
# FPM_CALLBACK_TOKEN=<token from Debug AI tab>
