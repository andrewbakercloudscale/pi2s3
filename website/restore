#!/usr/bin/env bash
# pi2s3 restore bootstrap
# Usage: curl -sL pi2s3.com/restore | bash
#
# What this does:
#   1. Installs restore dependencies (partclone, pigz, pv, AWS CLI v2)
#   2. Prompts for AWS credentials if not configured
#   3. Clones pi2s3 into ~/pi2s3 (or pulls latest if already there)
#   4. Runs pi-image-restore.sh — which lists your S3 backups and
#      streams the selected one directly to the target device

set -euo pipefail

# When piped through bash, stdin is the script not the terminal.
[[ -t 0 ]] || exec </dev/tty

# ── Colour output ─────────────────────────────────────────────────────────────
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    BOLD='\033[1m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
    YELLOW='\033[1;33m'; RED='\033[0;31m'; DIM='\033[2m'; RESET='\033[0m'
else
    BOLD=''; GREEN=''; CYAN=''; YELLOW=''; RED=''; DIM=''; RESET=''
fi

ok()     { echo -e "  ${GREEN}✓${RESET}  $*"; }
info()   { echo -e "  ${CYAN}→${RESET}  $*"; }
warn()   { echo -e "  ${YELLOW}⚠${RESET}  $*"; }
die()    { echo -e "  ${RED}✗${RESET}  $*" >&2; exit 1; }
section(){ echo -e "\n${BOLD}$*${RESET}"; }

echo ""
echo -e "${BOLD}  pi2s3 — restore${RESET}  ${DIM}https://pi2s3.com${RESET}"
echo -e "  ${DIM}────────────────────────────────────────${RESET}"

# ── System check ──────────────────────────────────────────────────────────────
section "System"

[[ "$(uname -s)" == "Linux" ]] || die "Restore requires Linux. Run this on the new Pi."

ARCH="$(uname -m)"
if [[ "${ARCH}" == "armv7l" || "${ARCH}" == "armv6l" ]]; then
    die "64-bit OS required. Flash Raspberry Pi OS (64-bit) and retry."
fi

PI_MODEL=""
if [[ -f /proc/device-tree/model ]]; then
    PI_MODEL=$(tr -d '\0' < /proc/device-tree/model 2>/dev/null || true)
fi
if [[ -n "${PI_MODEL}" ]]; then ok "${PI_MODEL} — ${ARCH}"; else ok "Linux — ${ARCH}"; fi

# ── Dependencies ──────────────────────────────────────────────────────────────
section "Dependencies"

if command -v apt-get &>/dev/null; then
    PKGS=()
    for pkg in git partclone pigz pv unzip; do
        dpkg -s "${pkg}" &>/dev/null || PKGS+=("${pkg}")
    done
    if [[ ${#PKGS[@]} -gt 0 ]]; then
        info "Installing: ${PKGS[*]}"
        sudo apt-get update -qq
        sudo apt-get install -y -qq "${PKGS[@]}"
    fi
    ok "git partclone pigz pv"
else
    command -v git       &>/dev/null || die "git not found. Install it and retry."
    command -v partclone &>/dev/null || die "partclone not found. Install it and retry."
    command -v pigz      &>/dev/null || warn "pigz not found — will fall back to gzip (slower)."
fi

if command -v aws &>/dev/null; then
    ok "AWS CLI: $(aws --version 2>&1 | head -1)"
else
    info "Installing AWS CLI v2..."
    if [[ "${ARCH}" == "aarch64" ]]; then
        AWS_URL="https://awscli.amazonaws.com/awscli-exe-linux-aarch64.zip"
    else
        AWS_URL="https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip"
    fi
    curl -sL "${AWS_URL}" -o /tmp/awscliv2.zip
    unzip -q /tmp/awscliv2.zip -d /tmp
    sudo /tmp/aws/install --update
    rm -rf /tmp/awscliv2.zip /tmp/aws
    ok "AWS CLI installed: $(aws --version 2>&1 | head -1)"
fi

# ── AWS credentials ───────────────────────────────────────────────────────────
section "AWS"

if aws sts get-caller-identity &>/dev/null 2>&1; then
    ok "Credentials configured ($(aws sts get-caller-identity --query 'Arn' --output text 2>/dev/null || echo 'ok'))"
else
    info "AWS credentials not configured."
    echo ""
    echo "  You need your AWS Access Key ID and Secret Access Key."
    echo "  These were generated when you set up pi2s3 on your original Pi."
    echo "  Find them in your password manager or IAM console."
    echo ""
    aws configure
    aws sts get-caller-identity &>/dev/null \
        || die "AWS credentials invalid. Check key/secret and region."
    ok "AWS credentials configured."
fi

# ── Clone or update repo ──────────────────────────────────────────────────────
section "pi2s3"

INSTALL_DIR="${HOME}/pi2s3"
REPO_URL="https://github.com/andrewbakercloudscale/pi2s3.git"

if [[ -d "${INSTALL_DIR}/.git" ]]; then
    info "Already installed — pulling latest..."
    git -C "${INSTALL_DIR}" pull --ff-only
    ok "Up to date ($(git -C "${INSTALL_DIR}" rev-parse --short HEAD))"
else
    info "Cloning into ${INSTALL_DIR}..."
    git clone "${REPO_URL}" "${INSTALL_DIR}"
    ok "Cloned ($(git -C "${INSTALL_DIR}" rev-parse --short HEAD))"
fi

# ── Hand off to restore script ────────────────────────────────────────────────
echo ""
echo -e "  ${DIM}────────────────────────────────────────${RESET}"
echo ""

exec bash "${INSTALL_DIR}/pi-image-restore.sh"
