#!/usr/bin/env bash
# pi2s3 restore bootstrap
# Usage: curl -sL pi2s3.com/restore | bash
#
# What this does:
#   1. Installs restore dependencies (partclone, pigz, pv, AWS CLI v2)
#   2. Prompts for AWS credentials if not configured
#   3. Clones pi2s3 into ~/pi2s3 (or pulls latest if already there)
#   4. Runs pi-image-restore.sh — which lists your S3 backups and
#      streams the selected one directly to the target device
#
# NOTE: Run this ON THE PI after you have SSH access.
# SSH options:
#   LAN  — ssh pi@<hostname>.local  (ethernet or WiFi, same network)
#   Remote / WiFi-only — SSH via Cloudflare tunnel (see extras/DR-quickstart.md)

set -euo pipefail

# When piped through bash, stdin is the script not the terminal.
# Skip TTY redirect in non-interactive mode (RESTORE_YES=true means no prompts needed).
[[ -t 0 ]] || [[ -n "${RESTORE_YES:-}" ]] || exec </dev/tty

# ── Colour output ─────────────────────────────────────────────────────────────
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    BOLD='\033[1m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
    YELLOW='\033[1;33m'; RED='\033[0;31m'; DIM='\033[2m'; RESET='\033[0m'
else
    BOLD=''; GREEN=''; CYAN=''; YELLOW=''; RED=''; DIM=''; RESET=''
fi

ok()     { echo -e "  ${GREEN}✓${RESET}  $*"; }
info()   { echo -e "  ${CYAN}→${RESET}  $*"; }
warn()   { echo -e "  ${YELLOW}⚠${RESET}  $*"; }
die()    { echo -e "  ${RED}✗${RESET}  $*" >&2; exit 1; }
section(){ echo -e "\n${BOLD}$*${RESET}"; }

echo ""
echo -e "${BOLD}  pi2s3 — restore${RESET}  ${DIM}https://pi2s3.com${RESET}"
echo -e "  ${DIM}────────────────────────────────────────${RESET}"

# ── System check ──────────────────────────────────────────────────────────────
section "System"

[[ "$(uname -s)" == "Linux" ]] || die "Restore requires Linux. Run this on the new Pi."

ARCH="$(uname -m)"
if [[ "${ARCH}" == "armv7l" || "${ARCH}" == "armv6l" ]]; then
    die "64-bit OS required. Flash Raspberry Pi OS (64-bit) and retry."
fi

PI_MODEL=""
if [[ -f /proc/device-tree/model ]]; then
    PI_MODEL=$(tr -d '\0' < /proc/device-tree/model 2>/dev/null || true)
fi
if [[ -n "${PI_MODEL}" ]]; then ok "${PI_MODEL} — ${ARCH}"; else ok "Linux — ${ARCH}"; fi

# ── Network check ─────────────────────────────────────────────────────────────
section "Network"

if ip route show default &>/dev/null 2>&1 && \
   timeout 5 bash -c 'echo >/dev/tcp/1.1.1.1/443' 2>/dev/null; then
    ok "Internet reachable"
else
    echo ""
    warn "No internet connection detected."
    echo ""
    echo "  If you are on WiFi, check:"
    echo "    nmcli device status"
    echo "    nmcli radio wifi"
    echo ""
    echo "  To diagnose all connectivity issues:"
    echo "    sudo bash ~/pi2s3/extras/diagnose-restore.sh"
    echo ""
    printf "  Continue anyway? [y/N] "; read -r _ans
    [[ "${_ans,,}" == "y" ]] || exit 1
fi

# ── Dependencies ──────────────────────────────────────────────────────────────
section "Dependencies"

if command -v apt-get &>/dev/null; then
    PKGS=()
    for pkg in git partclone pigz pv unzip jq; do
        dpkg -s "${pkg}" &>/dev/null || PKGS+=("${pkg}")
    done
    if [[ ${#PKGS[@]} -gt 0 ]]; then
        info "Installing: ${PKGS[*]}"
        sudo apt-get update -qq
        sudo apt-get install -y -qq "${PKGS[@]}"
    fi
    ok "git partclone pigz pv jq"
else
    command -v git       &>/dev/null || die "git not found. Install it and retry."
    command -v partclone &>/dev/null || die "partclone not found. Install it and retry."
    command -v pigz      &>/dev/null || warn "pigz not found — will fall back to gzip (slower)."
fi

if command -v aws &>/dev/null; then
    ok "AWS CLI: $(aws --version 2>&1 | head -1)"
else
    info "Installing AWS CLI v2..."
    if [[ "${ARCH}" == "aarch64" ]]; then
        AWS_URL="https://awscli.amazonaws.com/awscli-exe-linux-aarch64.zip"
    else
        AWS_URL="https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip"
    fi
    curl -sL "${AWS_URL}" -o /tmp/awscliv2.zip
    unzip -q /tmp/awscliv2.zip -d /tmp
    sudo /tmp/aws/install --update
    rm -rf /tmp/awscliv2.zip /tmp/aws
    ok "AWS CLI installed: $(aws --version 2>&1 | head -1)"
fi

# ── AWS credentials ───────────────────────────────────────────────────────────
section "AWS"

[[ -n "${AWS_PROFILE:-}" ]] && export AWS_PROFILE

if aws sts get-caller-identity &>/dev/null 2>&1; then
    ok "Credentials configured ($(aws sts get-caller-identity --query 'Arn' --output text 2>/dev/null || echo 'ok'))"
else
    info "AWS credentials not configured."
    echo ""
    echo "  You need your AWS Access Key ID and Secret Access Key."
    echo "  These were generated when you set up pi2s3 on your original Pi."
    echo "  Find them in your password manager or IAM console."
    echo ""
    aws configure
    aws sts get-caller-identity &>/dev/null \
        || die "AWS credentials invalid. Check key/secret and region."
    ok "AWS credentials configured."
fi

# ── Clone or update repo ──────────────────────────────────────────────────────
section "pi2s3"

INSTALL_DIR="${HOME}/pi2s3"
REPO_URL="https://github.com/andrewbakercloudscale/pi2s3.git"

if [[ -d "${INSTALL_DIR}/.git" ]]; then
    info "Already installed — updating..."
    # Do NOT let a dirty/diverged tree abort the whole restore. A bare recovery
    # box may carry a local patch; in that case continue with the installed
    # version rather than dying. Opt into auto-stash with PI2S3_FORCE_UPDATE=1
    # (never stash silently — that could hide an intentional local fix).
    if ! git -C "${INSTALL_DIR}" pull --ff-only 2>/dev/null; then
        if [[ "${PI2S3_FORCE_UPDATE:-}" == "1" ]]; then
            warn "Local changes present — stashing and updating (PI2S3_FORCE_UPDATE=1)."
            git -C "${INSTALL_DIR}" stash -u >/dev/null 2>&1 || true
            git -C "${INSTALL_DIR}" pull --ff-only \
                || warn "Update still failed — continuing with the installed version."
        else
            warn "Could not fast-forward ${INSTALL_DIR} (local changes or diverged)."
            warn "Continuing with the INSTALLED version. To update later, run one of:"
            warn "    git -C ${INSTALL_DIR} stash && git -C ${INSTALL_DIR} pull --ff-only"
            warn "    PI2S3_FORCE_UPDATE=1 <re-run>   (stashes automatically)"
        fi
    fi
    ok "Using $(git -C "${INSTALL_DIR}" rev-parse --short HEAD)"
else
    info "Cloning into ${INSTALL_DIR}..."
    git clone "${REPO_URL}" "${INSTALL_DIR}"
    ok "Cloned ($(git -C "${INSTALL_DIR}" rev-parse --short HEAD))"
fi

# ── Config file ───────────────────────────────────────────────────────────────
section "Config"

CONFIG_FILE="${INSTALL_DIR}/config.env"

if [[ -f "${CONFIG_FILE}" ]]; then
    ok "config.env exists"
elif [[ -n "${RESTORE_S3_BUCKET:-}" ]]; then
    {
        echo "S3_BUCKET=\"${RESTORE_S3_BUCKET}\""
        echo "S3_REGION=\"${RESTORE_S3_REGION:-us-east-1}\""
        [[ -n "${AWS_PROFILE:-}" ]] && echo "AWS_PROFILE=\"${AWS_PROFILE}\""
    } > "${CONFIG_FILE}"
    ok "config.env created (${RESTORE_S3_BUCKET} / ${RESTORE_S3_REGION:-us-east-1})"
else
    echo ""
    info "S3 bucket not configured."
    read -r -p "  S3 bucket name: " _s3b
    read -r -p "  S3 region [us-east-1]: " _s3r
    {
        echo "S3_BUCKET=\"${_s3b}\""
        echo "S3_REGION=\"${_s3r:-us-east-1}\""
    } > "${CONFIG_FILE}"
    ok "config.env created"
fi

# ── Hand off to restore script ────────────────────────────────────────────────
echo ""
echo -e "  ${DIM}────────────────────────────────────────${RESET}"
echo ""

RESTORE_ARGS=()
[[ -n "${RESTORE_DEVICE:-}" ]]      && RESTORE_ARGS+=(--device "${RESTORE_DEVICE}")
[[ "${RESTORE_YES:-}" == "true" ]]  && RESTORE_ARGS+=(--yes)
[[ -n "${RESTORE_DATE:-}" ]]        && RESTORE_ARGS+=(--date "${RESTORE_DATE}")
[[ -n "${RESTORE_POST_SCRIPT:-}" ]] && RESTORE_ARGS+=(--post-restore "${RESTORE_POST_SCRIPT}")

[[ ${#RESTORE_ARGS[@]} -gt 0 ]] && info "Flags: ${RESTORE_ARGS[*]}"

exec bash "${INSTALL_DIR}/pi-image-restore.sh" "${RESTORE_ARGS[@]}"
