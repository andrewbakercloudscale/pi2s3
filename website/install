#!/usr/bin/env bash
# pi2s3 one-line installer
# Usage: curl -sL pi2s3.com/install | bash
#
# What this does:
#   1. Detects your Pi model and architecture
#   2. Installs git if needed
#   3. Clones pi2s3 into ~/pi2s3 (or pulls latest if already there)
#   4. Runs install.sh — which prompts for S3 bucket, region, ntfy URL,
#      installs all dependencies, configures cron, and runs a dry-run test

set -euo pipefail

# When piped through bash stdin is the script, not the terminal.
# Redirect to /dev/tty so interactive prompts work.
[[ -t 0 ]] || exec </dev/tty

# ── Colour output ─────────────────────────────────────────────────────────────
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    BOLD='\033[1m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
    YELLOW='\033[1;33m'; RED='\033[0;31m'; DIM='\033[2m'; RESET='\033[0m'
else
    BOLD=''; GREEN=''; CYAN=''; YELLOW=''; RED=''; DIM=''; RESET=''
fi

ok()     { echo -e "  ${GREEN}✓${RESET}  $*"; }
info()   { echo -e "  ${CYAN}→${RESET}  $*"; }
warn()   { echo -e "  ${YELLOW}⚠${RESET}  $*"; }
die()    { echo -e "  ${RED}✗${RESET}  $*" >&2; exit 1; }
section(){ echo -e "\n${BOLD}$*${RESET}"; }

echo ""
echo -e "${BOLD}  pi2s3 — installer${RESET}  ${DIM}https://pi2s3.com${RESET}"
echo -e "  ${DIM}────────────────────────────────────────${RESET}"

# ── System check ──────────────────────────────────────────────────────────────
section "System"

[[ "$(uname -s)" == "Linux" ]] || die "pi2s3 requires Linux. (Detected: $(uname -s))"

ARCH="$(uname -m)"

PI_MODEL=""
if [[ -f /proc/device-tree/model ]]; then
    PI_MODEL=$(tr -d '\0' < /proc/device-tree/model 2>/dev/null || true)
elif grep -q "Raspberry Pi" /proc/cpuinfo 2>/dev/null; then
    PI_MODEL=$(grep "^Model" /proc/cpuinfo 2>/dev/null | head -1 | cut -d: -f2- | xargs || true)
fi

if [[ -n "${PI_MODEL}" ]]; then
    ok "${PI_MODEL} — ${ARCH}"
else
    warn "Could not detect Pi model — continuing (${ARCH})"
fi

# Warn on 32-bit: partclone and AWS CLI are much better tested on aarch64
if [[ "${ARCH}" == "armv7l" || "${ARCH}" == "armv6l" ]]; then
    warn "32-bit ARM detected. 64-bit Raspberry Pi OS is recommended for best compatibility."
fi

# ── Install git ───────────────────────────────────────────────────────────────
section "Dependencies"

if command -v git &>/dev/null; then
    ok "git $(git --version | awk '{print $3}')"
else
    info "Installing git..."
    if command -v apt-get &>/dev/null; then
        sudo apt-get install -y -qq git
    elif command -v dnf &>/dev/null; then
        sudo dnf install -y -q git
    elif command -v yum &>/dev/null; then
        sudo yum install -y -q git
    else
        die "git not found and no supported package manager. Install git manually then re-run."
    fi
    ok "git installed"
fi

# ── Clone or update repo ──────────────────────────────────────────────────────
section "pi2s3"

INSTALL_DIR="${HOME}/pi2s3"
REPO_URL="https://github.com/andrewbakercloudscale/pi2s3.git"

if [[ -d "${INSTALL_DIR}/.git" ]]; then
    info "Already installed — pulling latest..."
    git -C "${INSTALL_DIR}" pull --ff-only
    ok "Up to date ($(git -C "${INSTALL_DIR}" rev-parse --short HEAD))"
else
    info "Cloning into ${INSTALL_DIR}..."
    git clone "${REPO_URL}" "${INSTALL_DIR}"
    ok "Cloned ($(git -C "${INSTALL_DIR}" rev-parse --short HEAD))"
fi

# ── Hand off to install.sh ────────────────────────────────────────────────────
echo ""
echo -e "  ${DIM}────────────────────────────────────────${RESET}"
echo ""

exec bash "${INSTALL_DIR}/install.sh"
